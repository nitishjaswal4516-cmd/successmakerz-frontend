# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/successmakerz
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/successmakerz

# Port for backend server
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
